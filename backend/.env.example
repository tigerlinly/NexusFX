# =============================================================
# 🚀 NEXUSFX - PRODUCTION ENVIRONMENT CONFIGURATION
# ⚠️ ข้อควรระวัง: อย่าลืมเปลี่ยนค่าตัวแปรรหัสผ่าน/คีย์ต่างๆ ก่อนนำขึ้นเซิร์ฟเวอร์
# =============================================================

# -------------------------------------------------------------
# 🗄️ Database (ตั้งค่าฐานข้อมูล PostgreSQL)
# -------------------------------------------------------------
# ตัวอย่าง: postgresql://[USER]:[PASSWORD]@[HOST]:[PORT]/[DATABASE_NAME]
DATABASE_URL=postgresql://postgres:password@localhost:5432/nexusfx
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-db-password-change-this
POSTGRES_DB=nexusfx

# -------------------------------------------------------------
# 🔐 Security & JWT (กุญแจเข้ารหัส API - ❌ ห้ามหลุดเด็ดขาด)
# -------------------------------------------------------------
# ใส่ข้อความรันดอม หรือรหัสยาวๆ กุญแจนี้มีผลต่อการสร้าง Login Token ของระบบ
JWT_SECRET=your-super-secret-jwt-key-for-nexusfx-production
JWT_EXPIRES_IN=7d

# สำหรับเข้ารหัสข้อมูลอ่อนไหวที่เก็บใน Table Broker / MetaApi Token
ENCRYPTION_KEY=your-32-char-encryption-key-here
ENCRYPTION_SALT=your-unique-deployment-salt

# -------------------------------------------------------------
# 🌐 Server & App Config (การตั้งค่าทั่วไปของระบบ)
# -------------------------------------------------------------
PORT=4000
# ⚠️ ถ้าขึั้น Production แล้ว ต้องเปลี่ยนเป็น NODE_ENV=production
NODE_ENV=development

# FRONTEND_URL: ลิงก์โดเมนหลักของหน้าเว็บ (ใช้สำหรับสร้างลิงก์แนบกลับไปในอีเมล)
FRONTEND_URL=http://localhost:5173
# ตัวอย่างสำหรับ Deployment: FRONTEND_URL=https://app.nexusfx.com

# CORS_ORIGINS: ให้ใส่โดเมนหน้าแรกที่อนุญาตให้เรียก API ได้ (คั่นด้วยคอมม่า) ป้องกันเว็บอื่นดูดข้อมูล
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# ตัวอย่างสำหรับ Deployment: CORS_ORIGINS=https://app.nexusfx.com,https://www.nexusfx.com

# -------------------------------------------------------------
# 📧 Email Server (SMTP) - สำหรับระบบรีเซ็ตรหัสผ่านและการแจ้งเตือนนอกระบบ
# -------------------------------------------------------------
# ตัวอย่างการตั้งค่าสำหรับใช้งาน Gmail (ต้องไปเปิด App Passwords 16 หลักใน Google Account ก่อน):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=abcdabcdabcdabcd

# ตัวอย่างการตั้งค่าสำหรับใช้งาน Private SMTP / Hostinger:
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=support@yourdomain.com
SMTP_PASS=your-secure-password

# -------------------------------------------------------------
# 💸 Payment Gateway (Stripe - สำหรับลูกค้าเติมเงินเข้า Wallet)
# -------------------------------------------------------------
# จำเป็นต้องใส่ Secret Key ของ Stripe เพื่อให้ระบบฝากเงินหน้าเว็บทำงานได้ (ในส่วนนี้เราบังคับรับเงินจริงแล้ว)
# ⚠️ อย่าลืมแก้ให้เป็นของบัญชีจริงในระบบ Production (ของจริงจะขึ้นต้นด้วย sk_live_...)
STRIPE_SECRET_KEY=sk_test_1234567890abcdef

# -------------------------------------------------------------
# 📈 Trading API (MetaAPI MT5 Connection - ปล่อยว่างไว้ถ้ายังไม่เชื่อม Bot ในตอนนี้)
# -------------------------------------------------------------
META_API_TOKEN=your-metaapi-token
