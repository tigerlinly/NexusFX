# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/nexusfx
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-db-password-change-this
POSTGRES_DB=nexusfx

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=7d

# Encryption (for API keys stored in DB) — if not set, falls back to JWT_SECRET
ENCRYPTION_KEY=your-32-char-encryption-key-here
ENCRYPTION_SALT=your-unique-deployment-salt

# MetaApi (MT5 Connection)
META_API_TOKEN=your-metaapi-token

# Server
PORT=4000
NODE_ENV=development

# CORS — comma-separated allowed origins (for production)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
